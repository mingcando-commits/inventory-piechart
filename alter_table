-- ============================================================================
-- Migration: per-item optional exchange rate / adjustment factor, with a
-- global fallback, to support:
--   - Editing/deleting items from the app (new feature)
--   - "全域匯率及全域調整factor維護" admin screen
--   - "當前資產估值查詢" valuation report
--
-- Safe to re-run (uses IF NOT EXISTS / ON CONFLICT DO NOTHING throughout).
-- Run this in the Supabase SQL Editor, or via psql against your database.
-- ============================================================================

-- 1. Make exchange_rate and tax_coefficient optional on item_master.
--    NULL now means "use the global default at valuation time" instead of
--    an item-specific value. Existing rows keep their current values --
--    nothing changes for items that already have a rate/factor set.
ALTER TABLE public.item_master ALTER COLUMN exchange_rate DROP NOT NULL;
ALTER TABLE public.item_master ALTER COLUMN exchange_rate DROP DEFAULT;
ALTER TABLE public.item_master ALTER COLUMN tax_coefficient DROP NOT NULL;
ALTER TABLE public.item_master ALTER COLUMN tax_coefficient DROP DEFAULT;

-- 2. New singleton table holding the two global fallback values.
--    The CHECK (id = 1) constraint enforces there's ever only one row.
CREATE TABLE IF NOT EXISTS public.system_settings (
    id SMALLINT PRIMARY KEY DEFAULT 1,
    global_exchange_rate NUMERIC(8,4) NOT NULL,
    global_tax_coefficient NUMERIC(6,4) NOT NULL,
    last_update_date DATE DEFAULT CURRENT_DATE,
    last_update_operator_id INTEGER REFERENCES public.operator_master(operator_id),
    CONSTRAINT system_settings_single_row CHECK (id = 1)
);

-- 3. Seed the single settings row if it doesn't exist yet.
--    32.0000 / 0.0500 are just reasonable starting values -- change them
--    later from the app's "全域匯率及全域調整factor維護" screen.
INSERT INTO public.system_settings (id, global_exchange_rate, global_tax_coefficient)
VALUES (1, 32.0000, 0.0500)
ON CONFLICT (id) DO NOTHINT;
