<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA">

    <RelativeLayout
        android:id="@+id/topBarChart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="64dp"
        android:background="#2A3B50"
        android:paddingHorizontal="16dp"
        android:elevation="8dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="#FFFFFF"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tvChartTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@id/btnBack"
            android:layout_marginStart="8dp"
            android:text="庫存趨勢圖表"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvSwitchLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="顯示：件數"
            android:textColor="#2A3B50"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Switch
            android:id="@+id/switchValueToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="金額 (TWD)" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvSelectionDetail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="72dp"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="8dp"
        android:text="點擊任一長條圖，查看該月各商品的詳細數字。"
        android:textColor="#495057"
        android:textSize="13sp"
        android:lineSpacingExtra="2dp" />

    <com.github.mikephil.charting.charts.BarChart
        android:id="@+id/barChartMonthly"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="8dp"
        android:layout_marginBottom="8dp" />

</LinearLayout>
